DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@localhost:5432/online_examination
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SQL_ECHO=false
CORS_ORIGINS=http://localhost:5173

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Online Examination <no-reply@example.com>

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CODE_EXECUTION_RESULT_TTL_SECONDS=3600

CODE_RUNNER_IMAGE=oes-code-runner:latest
